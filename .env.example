# OPENAI_API_KEY: Required for OpenAI API calls.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# OPENAI_MODEL: Chat model used by server.ts (default: gpt-5.4-mini)
OPENAI_MODEL="gpt-5.4-mini"

# Firestore persistence (required for primary study storage)
FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.firebasestorage.app"
FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"
FIREBASE_APP_ID="YOUR_APP_ID"
# Optional: change default collection name ("sessions")
# FIRESTORE_SESSIONS_COLLECTION="sessions"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_ENABLE_DEV_TOOLS: Show in-app dev controls (condition switch/jump/reset/export links).
# Keep this "false" for participant runs.
VITE_ENABLE_DEV_TOOLS="false"

# ENABLE_ADMIN_ROUTES: Allow server export route (/api/export).
# Keep this "false" for participant runs.
ENABLE_ADMIN_ROUTES="false"

# ENABLE_MOCK_CHAT: Optional explicit fallback mode when OPENAI_API_KEY is missing.
# Keep this "false" for normal real-API development.
ENABLE_MOCK_CHAT="false"

# STUDY_DATA_DIR: Optional absolute directory for local JSON persistence.
# Default is ~/.english-interaction-study
# STUDY_DATA_DIR="/absolute/path/to/data-dir"
